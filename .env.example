# ─────────────────────────────────────────────
# EconPulse — Environment Variables
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────

# ── Local PostgreSQL (Development) ────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=economicdb
DB_USER=postgres
DB_PASSWORD=your_postgres_password

# ── AWS Redshift (Production) ─────────────────
REDSHIFT_HOST=your-cluster.us-east-1.redshift.amazonaws.com
REDSHIFT_PORT=5439
REDSHIFT_DB=economicdb
REDSHIFT_USER=admin
REDSHIFT_PASSWORD=your_redshift_password

# ── AWS Credentials ───────────────────────────
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1

# ── S3 Buckets ────────────────────────────────
S3_RAW_BUCKET=economic-insights-raw
S3_PROCESSED_BUCKET=economic-insights-processed
S3_SCRIPTS_BUCKET=economic-insights-scripts

# ── AWS Glue ──────────────────────────────────
GLUE_JOB_NAME=economic-etl
REDSHIFT_CONN=economic-redshift

# ── API Keys ──────────────────────────────────
# Google Maps: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=AIzaSy_YOUR_GOOGLE_MAPS_KEY_HERE

# FRED (Federal Reserve): https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# World Bank: No key needed (public API)

# ── Notifications ─────────────────────────────
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789:economic-pipeline-alerts

# ── App Settings ──────────────────────────────
REFRESH_INTERVAL_MS=30000
APP_ENV=development
